 \/* 説明テキスト *\/\n  .line-instruction-text {\n    font-size: 1.4rem;\n    line-height: 1.8;\n    color: #333;\n    margin: 0;\n  }\n\n  \/* スマホでの微調整 *\/\n  @media screen and (max-width: 749px) {\n    .line-registration-section {\n      padding-top: 40px;\n      padding-bottom: 40px;\n    }\n    .line-section-title {\n      font-size: 2.0rem;\n      margin-bottom: 30px;\n    }\n  }\n<\/style>","color_scheme":"","padding_top":40,"padding_bottom":52}},"custom_liquid_xB9fKg":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<div class=\"line-guide-section page-width\" data-line-guide>\n  \n  <h2 class=\"line-guide-title\">LINE ID連携方法<\/h2>\n\n  <div class=\"line-tab-header\" role=\"tablist\" aria-label=\"LINE ID連携方法のタブ\">\n    <button type=\"button\"\n            class=\"line-tab-item active\"\n            data-line-tab=\"tab-registered\"\n            role=\"tab\"\n            aria-selected=\"true\"\n            aria-controls=\"tab-registered\">\n      会員登録がお済みの方\n    <\/button>\n    <button type=\"button\"\n            class=\"line-tab-item\"\n            data-line-tab=\"tab-new\"\n            role=\"tab\"\n            aria-selected=\"false\"\n            aria-controls=\"tab-new\">\n      初めて会員登録する方\n    <\/button>\n  <\/div>\n\n  <div class=\"line-tab-body\">\n    \n    <div id=\"tab-registered\" class=\"line-tab-content active\" role=\"tabpanel\">\n      <div class=\"line-step-grid\">\n        \n        <div class=\"step-item\">\n          <div class=\"step-header\">\n            <div class=\"step-number\">\n              <span class=\"step-label-en\">STEP<\/span>\n              <span class=\"step-digit\">1<\/span>\n            <\/div>\n            <p class=\"step-text\">\n              オンラインストアにログイン後、マイページ画面の「連携する」ボタンをクリックしてください\n            <\/p>\n          <\/div>\n          <div class=\"step-image\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0790\/0699\/0569\/files\/step_1.webp?v=1769342298\" alt=\"手順1\">\n          <\/div>\n        <\/div>\n\n        <div class=\"step-item\">\n          <div class=\"step-header\">\n            <div class=\"step-number\">\n              <span class=\"step-label-en\">STEP<\/span>\n              <span class=\"step-digit\">2<\/span>\n            <\/div>\n            <p class=\"step-text\">\n              許諾画面では「許可する」をタップしてください\n            <\/p>\n          <\/div>\n          <div class=\"step-image\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0790\/0699\/0569\/files\/step_2-2.png?v=1769344829\" alt=\"手順2\">\n          <\/div>\n        <\/div>\n\n        <div class=\"step-item\">\n          <div class=\"step-header\">\n            <div class=\"step-number\">\n              <span class=\"step-label-en\">STEP<\/span>\n              <span class=\"step-digit\">3<\/span>\n            <\/div>\n            <p class=\"step-text\">\n              マイページを開き「連携済」の文字が表示されたら連携完了となります\n            <\/p>\n          <\/div>\n          <div class=\"step-image\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0790\/0699\/0569\/files\/step_4.webp?v=1769342298\" alt=\"手順3\">\n          <\/div>\n        <\/div>\n\n      <\/div>\n      \n      <div class=\"line-bottom-button\">\n        <a href=\"{{ routes.account_login_url }}\" class=\"line-btn-black\" target=\"_self\" rel=\"nofollow\">ログインはこちら<\/a>\n      <\/div>\n    <\/div>\n\n    <div id=\"tab-new\" class=\"line-tab-content\" role=\"tabpanel\">\n      <div class=\"line-step-grid\">\n        \n        <div class=\"step-item\">\n          <div class=\"step-header\">\n            <div class=\"step-number\">\n              <span class=\"step-label-en\">STEP<\/span>\n              <span class=\"step-digit\">1<\/span>\n            <\/div>\n            <p class=\"step-text\">\n              「アカウント作成」をクリックし、アカウント情報を入力して登録手続きを進めてください\n            <\/p>\n          <\/div>\n          <div class=\"step-image\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0790\/0699\/0569\/files\/step_1_119f2392-43dc-4a53-ab96-b51a6c3a5dcc.webp?v=1769342298\" alt=\"新規手順1\">\n          <\/div>\n        <\/div>\n\n        <div class=\"step-item\">\n          <div class=\"step-header\">\n            <div class=\"step-number\">\n              <span class=\"step-label-en\">STEP<\/span>\n              <span class=\"step-digit\">2<\/span>\n            <\/div>\n            <p class=\"step-text\">\n              会員登録完了後、マイページ画面の「連携する」ボタンをクリックしてください\n            <\/p>\n          <\/div>\n          <div class=\"step-image\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0790\/0699\/0569\/files\/step_1.webp?v=1769342298\" alt=\"新規手順2\">\n          <\/div>\n        <\/div>\n\n        <div class=\"step-item\">\n          <div class=\"step-header\">\n            <div class=\"step-number\">\n              <span class=\"step-label-en\">STEP<\/span>\n              <span class=\"step-digit\">3<\/span>\n            <\/div>\n            <p class=\"step-text\">\n              許諾画面では「許可する」をタップしてください\n            <\/p>\n          <\/div>\n          <div class=\"step-image\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0790\/0699\/0569\/files\/step_2-2.png?v=1769344829\" alt=\"新規手順3\">\n          <\/div>\n        <\/div>\n\n        <div class=\"step-item\">\n          <div class=\"step-header\">\n            <div class=\"step-number\">\n              <span class=\"step-label-en\">STEP<\/span>\n              <span class=\"step-digit\">4<\/span>\n            <\/div>\n            <p class=\"step-text\">\n              マイページを開き「連携済」の文字が表示されたら連携完了となります\n            <\/p>\n          <\/div>\n          <div class=\"step-image\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0790\/0699\/0569\/files\/step_3.webp?v=1769342298\" alt=\"新規手順4\">\n          <\/div>\n        <\/div>\n\n      <\/div>\n\n      <div class=\"line-bottom-button\">\n        <a href=\"{{ routes.account_login_url }}\" class=\"line-btn-black\" target=\"_self\" rel=\"nofollow\">アカウントを作成<\/a>\n        <p class=\"line-btn-note\">※遷移先の「アカウントを作成」から新規登録できます<\/p>\n      <\/div>\n    <\/div>\n\n  <\/div>\n<\/div>\n\n<style>\n  \/* =====================\n     全体のレイアウト\n     ===================== *\/\n  .line-guide-section {\n    padding-top: 60px;\n    padding-bottom: 80px;\n    max-width: 1000px; \/* PCで2列並ぶので少し広めに *\/\n    margin: 0 auto;\n  }\n\n  .line-guide-title {\n    text-align: center;\n    font-size: 2.2rem;\n    font-weight: 500;\n    letter-spacing: 0.05rem;\n    margin-bottom: 50px;\n  }\n\n  \/* =====================\n     タブ切り替え部分\n     ===================== *\/\n  .line-tab-header {\n    display: flex;\n    justify-content: center;\n    border-bottom: 1px solid #e0e0e0;\n    margin-bottom: 60px;\n  }\n\n  .line-tab-item {\n    flex: 1;\n    max-width: 400px;\n    text-align: center;\n    font-size: 1.6rem;\n    padding-bottom: 15px;\n    cursor: pointer;\n    color: #888;\n    position: relative;\n    font-weight: 600;\n    transition: color 0.3s;\n    background: transparent;\n    border: 0;\n  }\n  \n  .line-tab-item.active {\n    color: #000;\n  }\n\n  .line-tab-item::after {\n    content: \"\";\n    position: absolute;\n    bottom: -1px;\n    left: 0;\n    width: 0%;\n    height: 2px;\n    background: #000;\n    transition: width 0.3s ease;\n  }\n  .line-tab-item.active::after {\n    width: 100%;\n  }\n\n  .line-tab-content {\n    display: none;\n    animation: fadeIn 0.6s ease;\n  }\n  .line-tab-content.active {\n    display: block;\n  }\n\n  \/* =====================\n     グリッドレイアウト (PC: 2列)\n     ===================== *\/\n  .line-step-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    column-gap: 60px;\n    row-gap: 80px;\n    align-items: start;\n  }\n\n  \/* =====================\n     STEPアイテムのデザイン\n     ===================== *\/\n  .step-item {\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n  }\n\n  .step-header {\n    display: flex;\n    align-items: baseline;\n    gap: 15px;\n  }\n\n  .step-number {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    line-height: 1;\n    flex-shrink: 0;\n  }\n  .step-label-en {\n    font-size: 1.0rem;\n    font-weight: 700;\n    letter-spacing: 0.05rem;\n    color: #333;\n    margin-bottom: 2px;\n  }\n  .step-digit {\n    font-size: 2.4rem;\n    font-weight: 700;\n    color: #333;\n  }\n\n  .step-text {\n    font-size: 1.4rem;\n    line-height: 1.6;\n    color: #333;\n    margin: 0;\n    flex-grow: 1;\n  }\n\n  .step-image img {\n    width: 100%;\n    height: auto;\n    border: 1px solid #eee;\n    display: block;\n  }\n\n  \/* =====================\n     黒いボタン\n     ===================== *\/\n  .line-bottom-button {\n    text-align: center;\n    margin-top: 80px;\n  }\n  \n  .line-btn-black {\n    display: inline-block;\n    background-color: #000;\n    color: #fff;\n    text-decoration: none;\n    padding: 18px 60px;\n    font-size: 1.4rem;\n    font-weight: 500;\n    transition: opacity 0.3s;\n    min-width: 300px;\n  }\n  .line-btn-black:hover {\n    opacity: 0.8;\n    color: #fff;\n  }\n\n  .line-btn-note{\n    margin: 12px 0 0;\n    font-size: 1.2rem;\n    color: #666;\n    text-align: center;\n    line-height: 1.6;\n  }\n\n  \/* =====================\n     スマホ対応\n     ===================== *\/\n  @media screen and (max-width: 749px) {\n    .line-guide-section {\n      padding-top: 40px;\n      padding-bottom: 60px;\n    }\n\n    .line-tab-header {\n      margin-bottom: 40px;\n    }\n    .line-tab-item {\n      font-size: 1.3rem;\n      padding-bottom: 10px;\n    }\n\n    .line-step-grid {\n      grid-template-columns: 1fr;\n      row-gap: 50px;\n    }\n\n    .step-header {\n      margin-bottom: 10px;\n    }\n    .step-text {\n      font-size: 1.3rem;\n    }\n\n    .line-bottom-button {\n      margin-top: 50px;\n    }\n    .line-btn-black {\n      width: 100%;\n      padding: 15px 0;\n      min-width: 0;\n    }\n  }\n\n  @keyframes fadeIn {\n    from { opacity: 0; transform: translateY(10px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n<\/style>\n\n<script>\n  (function () {\n    var root = document.querySelector('[data-line-guide]');\n    if (!root) return;\n\n    var tabs = root.querySelectorAll('.line-tab-item');\n    var panels = root.querySelectorAll('.line-tab-content');\n\n    function activate(targetId) {\n      tabs.forEach(function (t) {\n        var isActive = t.getAttribute('data-line-tab') === targetId;\n        t.classList.toggle('active', isActive);\n        t.setAttribute('aria-selected', isActive ? 'true' : 'false');\n      });\n      panels.forEach(function (p) {\n        p.classList.toggle('active', p.id === targetId);\n      });\n    }\n\n    tabs.forEach(function (tab) {\n      tab.addEventListener('click', function () {\n        var id = tab.getAttribute('data-line-tab');\n        if (!id) return;\n        activate(id);\n      });\n    });\n  })();\n<\/script>","color_scheme":"","padding_top":40,"padding_bottom":52}}},"order":["main","rich_text_PVYMge","image_with_text_McpC8y","multicolumn_WeLGwe","custom_liquid_wPQMEQ","custom_liquid_xB9fKg"]}