view_all_style":"outline","color_scheme":"scheme-1","image_ratio":"portrait","image_shape":"default","show_secondary_image":true,"show_vendor":false,"show_rating":false,"quick_add":"none","columns_mobile":"2","swipe_on_mobile":true,"padding_top":0,"padding_bottom":0}},"multicolumn_6e9cGq":{"type":"multicolumn","blocks":{"column_HJbtXe":{"type":"column","settings":{"image":"shopify://shop_images/FEATURE.jpg","title":"","text":"","link_label":"推しに会いにいく日♡","link":"https://www.topshell.jp/LP251217/"}},"column_zpaPh4":{"type":"column","settings":{"image":"shopify://shop_images/IMG_0444.jpg","title":"","text":"","link_label":"De bon core特集","link":"shopify://pages/the-bagmati"}},"column_FqPhk6":{"type":"column","disabled":true,"settings":{"title":"列","text":"<p>選択した商品、コレクション、ブログ記事に注目を集めるため、テキストと画像を組み合わせます。可用性、スタイル、またはレビュー提供についての詳細を追加します。</p>","link_label":"","link":""}}},"block_order":["column_HJbtXe","column_zpaPh4","column_FqPhk6"],"name":"FEATURE","settings":{"title":"FEATURE","heading_size":"h1","image_width":"full","image_ratio":"square","button_label":"","button_link":"","columns_desktop":3,"column_alignment":"left","background_style":"primary","color_scheme":"","columns_mobile":"1","swipe_on_mobile":false,"padding_top":0,"padding_bottom":0}},"custom_liquid_3QnnXw":{"type":"custom-liquid","name":"Blog <カスタムLiquid>","settings":{"custom_liquid":"<div id=\"blog-loader-section\" class=\"blog-section-wrapper\">\n  <div class=\"title-wrapper-with-link\">\n    <h2 class=\"title\">BLOG</h2>\n  </div>\n  \n  <div id=\"wp-blog-list\" class=\"blog-list\">\n    <p class=\"loading-text\">読み込み中...</p>\n  </div>\n\n  <div class=\"blog-view-all\">\n    <a href=\"https://topshell.jp/blog/\" target=\"_blank\" class=\"button blog-button\">過去ブログを見る</a>\n  </div>\n</div>\n\n<style>\n  /* =========================================\n     ブログセクション用 CSS (画像正方形・ボタン追加版)\n     ========================================= */\n  .blog-section-wrapper {\n    margin-top: 60px;\n    margin-bottom: 80px;\n    background-color: #ffffff;\n    max-width: 1200px;\n    margin-left: auto;\n    margin-right: auto;\n    padding: 0 1.5rem;\n  }\n\n  /* タイトルエリア */\n  .blog-section-wrapper .title-wrapper-with-link {\n    text-align: center;\n    margin-bottom: 50px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .blog-section-wrapper .title {\n    font-size: 26px;\n    font-weight: 400;\n    letter-spacing: 0.05em;\n    text-transform: uppercase;\n    margin-bottom: 5px;\n    color: #000;\n    margin: 0;\n  }\n  @media screen and (min-width: 750px) {\n    .blog-section-wrapper .title {\n      font-size: 36px; /* PCサイズ */\n    }\n  }\n\n  .blog-section-wrapper .title-wrapper-with-link::after {\n    content: \"ブログ\";\n    display: block;\n    font-size: 16px;\n    color: #333;\n    font-weight: 400;\n    margin-top: 5px;\n    letter-spacing: 0.05em;\n  }\n\n  /* リストとカードのベース */\n  .blog-list {\n    display: flex;\n    gap: 20px;\n  }\n  .blog-card {\n    text-decoration: none;\n    color: #333;\n  }\n\n  /* ▼ 画像の強制正方形設定（強化版） */\n  .blog-image-wrapper {\n    position: relative;\n    width: 100%;\n    aspect-ratio: 1 / 1; /* 正方形を強制 */\n    overflow: hidden;\n    background-color: #f0f0f0;\n  }\n  .blog-image {\n    width: 100%;\n    height: 100%;\n    object-fit: cover; /* 枠いっぱいにトリミング */\n    position: absolute;\n    top: 0;\n    left: 0;\n  }\n\n  .blog-title {\n    color: #333;\n    font-weight: 400;\n    margin-top: 0;\n    line-height: 1.4;\n  }\n  .blog-date {\n    font-size: 12px;\n    color: #999;\n    margin-top: 5px;\n    display: block;\n  }\n  .loading-text {\n    text-align: center;\n    width: 100%;\n    color: #999;\n  }\n\n  /* ▼ ボタンエリアのデザイン */\n  .blog-view-all {\n    text-align: center;\n    margin-top: 40px;\n  }\n  .blog-button {\n    background: #ffffff !important;\n    border: 1px solid #d0d0d0 !important;\n    color: #333 !important;\n    font-size: 12px !important;\n    line-height: 1 !important;\n    padding: 12px 0 !important;\n    min-width: 180px !important;\n    display: inline-flex !important;\n    justify-content: center !important;\n    align-items: center !important;\n    border-radius: 0 !important;\n    text-decoration: none !important;\n    transition: all 0.3s ease !important;\n    letter-spacing: 0.05em !important;\n  }\n  .blog-button:hover {\n    background: #f9f9f9 !important;\n    border-color: #333 !important;\n  }\n\n  /* -------------------------------------------\n     スマホ (749px以下) - 縦積み・横並びレイアウト\n     ------------------------------------------- */\n  @media screen and (max-width: 749px) {\n    .blog-list {\n      flex-direction: column;\n      gap: 20px;\n    }\n    .blog-card {\n      display: flex;\n      flex-direction: row;\n      align-items: center;\n      gap: 20px;\n    }\n    .blog-image-wrapper {\n      width: 130px; /* スマホ用固定幅 */\n      height: 130px;\n      flex-shrink: 0;\n      order: -1;\n    }\n    .blog-info {\n      text-align: left;\n      flex-grow: 1;\n    }\n    .blog-title {\n      font-size: 16px;\n    }\n  }\n\n  /* -------------------------------------------\n     PC (750px以上) - 横並び3列・縦積みレイアウト\n     ------------------------------------------- */\n  @media screen and (min-width: 750px) {\n    .blog-list {\n      flex-direction: row;\n      flex-wrap: wrap;\n      justify-content: center;\n      gap: 40px;\n    }\n    .blog-card {\n      width: calc(33.333% - 40px);\n      max-width: 350px;\n      display: flex;\n      flex-direction: column;\n      align-items: flex-start;\n      gap: 15px;\n    }\n    .blog-image-wrapper {\n      width: 100%;\n      /* aspect-ratio: 1/1 は共通設定で適用済 */\n      order: -1;\n      margin-bottom: 0px;\n    }\n    .blog-info {\n      order: 1;\n      text-align: left;\n      width: 100%;\n    }\n    .blog-title {\n      font-size: 20px;\n    }\n  }\n</style>\n\n<script>\n  // WordPressのRSSフィードURL\n  const rssUrl = 'https://topshell.jp/blog/feed/';\n  const apiUrl = `https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rssUrl)}`;\n\n  fetch(apiUrl)\n    .then(response => response.json())\n    .then(data => {\n      const container = document.getElementById('wp-blog-list');\n      const items = data.items.slice(0, 5); // 最新5件\n      \n      let html = '';\n      \n      if (items.length > 0) {\n        items.forEach(item => {\n          let imageUrl = item.thumbnail;\n          if (!imageUrl && item.enclosure && item.enclosure.link) {\n            imageUrl = item.enclosure.link;\n          }\n          if (!imageUrl) {\n            const imgMatch = item.content.match(/<img[^>]+src=\"([^\">]+)\"/);\n            if(imgMatch){\n              imageUrl = imgMatch[1];\n            } else {\n              imageUrl = 'https://placehold.co/600x600/eee/999?text=No+Image';\n            }\n          }\n\n          const date = new Date(item.pubDate);\n          const dateStr = `${date.getFullYear()}.${(date.getMonth()+1).toString().padStart(2, '0')}.${date.getDate().toString().padStart(2, '0')}`;\n\n          // target=\"_blank\" で新しいタブで開くように設定\n          html += `\n            <a href=\"${item.link}\" class=\"blog-card\" target=\"_blank\" rel=\"noopener\">\n              <div class=\"blog-image-wrapper\">\n                <img src=\"${imageUrl}\" alt=\"${item.title}\" class=\"blog-image\">\n              </div>\n              <div class=\"blog-info\">\n                <h3 class=\"blog-title\">${item.title}</h3>\n                <span class=\"blog-date\">${dateStr}</span>\n              </div>\n            </a>\n          `;\n        });\n        container.innerHTML = html;\n      } else {\n        container.innerHTML = '<p class=\"loading-text\">記事が見つかりませんでした。</p>';\n      }\n    })\n    .catch(error => {\n      console.error('Error fetching blog:', error);\n      document.getElementById('wp-blog-list').innerHTML = '<p class=\"loading-text\">ブログの読み込みに失敗しました。</p>';\n    });\n</script>","color_scheme":"","padding_top":0,"padding_bottom":0}}},"order":["slideshow_dx6e7K","slideshow_3m6NrV","ts_category_list_8URGVy","multicolumn_eXNyeb","featured_collection","multicolumn_6e9cGq","custom_liquid_3QnnXw"]}