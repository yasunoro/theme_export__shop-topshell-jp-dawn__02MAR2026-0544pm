{% comment %}
  TS Category List (FSF-like)
  - FSF DOM style: .category-section .section-header .category_list .category_item
  - Whole row clickable via <a> (no overlay)
  - Schema default validator workaround:
    optional text defaults use "__EMPTY__" and are filtered out in Liquid
{% endcomment %}

<section class="ts-category-list section-{{ section.id }}">
  <div class="category-section section--divider page-width">
    {% assign heading = section.settings.heading | strip %}
    {% assign subheading = section.settings.subheading | strip %}

    {% if heading != blank or subheading != blank and subheading != "__EMPTY__" %}
      <header class="section-header">
        {% if heading != blank %}
          <h2 class="section-header__title">{{ heading | escape }}</h2>
        {% endif %}
        {% if subheading != blank and subheading != "__EMPTY__" %}
          <p class="section-header__subtitle">{{ subheading | escape }}</p>
        {% endif %}
      </header>
    {% endif %}

    <ul class="category_list" role="list">
      {% for block in section.blocks %}
        {% if block.type == 'category' and block.settings.enabled %}
          {% assign label = block.settings.label | strip %}
          {% assign note = block.settings.note | strip %}
          {% assign link = block.settings.link %}

          <li class="category_item" {{ block.shopify_attributes }}>
            {% if link != blank %}
              <a href="{{ link }}">
                {{ label | escape }}
                {% if note != blank and note != "__EMPTY__" %}
                  <span class="ts-note">{{ note | escape }}</span>
                {% endif %}
              </a>
            {% else %}
              <span class="ts-disabled">
                {{ label | escape }}
                {% if note != blank and note != "__EMPTY__" %}
                  <span class="ts-note">{{ note | escape }}</span>
                {% endif %}
              </span>
            {% endif %}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "TS：カテゴリ（FSF寄せ）",
  "settings": [
    { "type": "text", "id": "heading", "label": "見出し", "default": "CATEGORY" },
    { "type": "text", "id": "subheading", "label": "補足（任意）", "default": "カテゴリーから探す" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "カテゴリ",
      "settings": [
        { "type": "checkbox", "id": "enabled", "label": "表示する", "default": true },
        { "type": "text", "id": "label", "label": "表示名", "default": "カテゴリ名" },
        { "type": "text", "id": "note", "label": "補足（任意）", "default": "__EMPTY__" },
        { "type": "url", "id": "link", "label": "リンク先" }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "TS：カテゴリ（FSF寄せ）",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
