<script>
// TS_TMP: inline JS #1 (DOMContentLoaded)
document.addEventListener("DOMContentLoaded", function() {
  // スマホサイズ(749px以下)の時だけ実行
  if (window.innerWidth <= 749) {
    // フッターの見出しをすべて取得
    const headings = document.querySelectorAll('.footer-block__heading');
    
    headings.forEach(function(heading) {
      // 既存のイベントをリセット（重複防止）
      let newHeading = heading.cloneNode(true);
      heading.parentNode.replaceChild(newHeading, heading);
      
      // クリックイベントを設定
      newHeading.addEventListener('click', function(e) {
        e.preventDefault(); // リンク動作をキャンセル
        
        // 1. 矢印回転 (.active)
        this.classList.toggle('active');
        
        // 2. 中身を表示 (.is-open) - 親要素から確実に探す
        let parentBlock = this.closest('.footer-block'); 
        let content = parentBlock ? parentBlock.querySelector('.footer-block__details-content') : null;
        
        if (content) {
          content.classList.toggle('is-open');
        }
      });
    });
  }
});
</script>

