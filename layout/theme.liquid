<script>
  // TS_TMP: inline JS #1 (DOMContentLoaded)
document.addEventListener("DOMContentLoaded", function() {
  // ■ 1. スマホ用アコーディオン機能（クラス付与のみ行う安全設計）
  if (window.innerWidth <= 749) {
    const headings = document.querySelectorAll('.footer-block__heading');
    headings.forEach(function(heading) {
      // 既存のイベントをリセット
      let newHeading = heading.cloneNode(true);
      heading.parentNode.replaceChild(newHeading, heading);
      
      // クリックイベント
      newHeading.addEventListener('click', function(e) {
        e.preventDefault();
        this.classList.toggle('active'); // 矢印の回転
        
        let parentBlock = this.closest('.footer-block'); 
        let content = parentBlock ? parentBlock.querySelector('.footer-block__details-content') : null;
        
        // クラスの付け外しだけを行う（アニメーションはCSSで制御）
        if (content) {
          if (content.classList.contains('is-open')) {
            content.classList.remove('is-open');
          } else {
            content.classList.add('is-open');
          }
        }
      });
    });
  }

  // ■ 2. インスタアイコン配置制御（重複防止・位置調整）
  var oldId = document.getElementById('force-insta-icon-container');
  var oldClass = document.querySelectorAll('.footer-custom-icon-row');
  if (oldId) oldId.remove();
  
  // アイコンHTML生成
  var instaHTML = `
    <div class="footer-custom-icon-row">
      <a href="https://www.instagram.com/topshell" target="_blank" style="display: flex; align-items: center; justify-content: center; height: 100%; width: 100%; text-decoration: none;">
