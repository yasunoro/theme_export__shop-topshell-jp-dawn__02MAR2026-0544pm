<style>
  /* ■ ハンバーガーメニュー（スマホ） ■ */
  /* 1.2秒かけてゆっくりと、余韻を残して開く設定 */
  .drawer__inner, 
  .menu-drawer__inner-container {
    transition-duration: 1.2s !important; 
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1) !important; /* 高級なブレーキ感 */
  }

  /* ■ PC版ドロップダウンメニュー ■ */
  /* ふわっと重力を感じながら降りてくる設定 */
  details[open] > .header__submenu,
  details[open] > .header__menu-item ul {
    animation: luxuriousFadeDown 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    transform-origin: top center;
  }
  @keyframes luxuriousFadeDown {
    from { opacity: 0; transform: translateY(-15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ■ フッターレイアウト＆アニメーション（ここが修正ポイント） ■ */
  @media screen and (max-width: 749px) {
    /* 1. 外側・内側の余白を完全リセット（デザイン崩れ防止） */
    .shopify-section-footer, .section-footer, .footer,
    .footer__content-top, .footer__blocks-wrapper, .footer-block.grid__item, .grid {
      margin-top: 0 !important;
      padding-top: 0 !important;
      margin-bottom: 0 !important;
      row-gap: 0 !important;
    }

    /* 2. アイコンと見出しの配置（13pxルールを厳守） */
    .footer-custom-icon-row, 
    .footer-block__heading {
      padding-top: 13px !important;    
      padding-bottom: 13px !important; 
      border-bottom: 1px solid #e8e8e1;
      margin: 0 !important;
      display: flex !important;
      align-items: center; 
      justify-content: center; 
      min-height: 48px;
      width: 100%; 
      font-size: 1.2rem; 
      letter-spacing: 0.1em; 
    }
    .footer__content-top { border-top: 1px solid #e8e8e1; }

    /* 3. アニメーション設定（デザインを変えずに中身だけ動かす） */
    .footer-block__details-content {
      display: block !important; /* アニメ用に常に存在させる */
      
      /* 閉じた状態：高さゼロ、透明、余白ゼロ */
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      margin-top: 0 !important;
      margin-bottom: 0 !important;
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      
      /* アニメーション：高さ・透明度・余白を別々の速度で動かしリッチに見せる */
      transition: max-height 1.2s cubic-bezier(0.22, 1, 0.36, 1), 
                  opacity 1.0s ease, 
                  margin 1.2s cubic-bezier(0.22, 1, 0.36, 1),
                  padding 1.2s cubic-bezier(0.22, 1, 0.36, 1);
    }
    
    /* 開いた状態：必要な高さと余白を与える */
    .footer-block__details-content.is-open {
      max-height: 1000px; /* 十分な高さを確保 */
      opacity: 1;
      
      /* ★修正点：外側のmarginではなく、内側のpaddingで余白を作ることで罫線をズレさせない */
      padding-bottom: 20px !important; 
    }

    /* 不要な要素の非表示 */
    .footer-block--newsletter { display: none !important; }
  }
</style>

</body>
</html>